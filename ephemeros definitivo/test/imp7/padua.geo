L=10;
H=1;
R=0.1;
X_INDENT=-4;
Point(1)={-L,-H,0};
Point(2)={L,-H,0};
Point(3)={L,H,0};
Point(5)={X_INDENT+R,H,0};
Point(6)={X_INDENT,H,0};
Point(7)={X_INDENT,H-R,0};
Point(8)={X_INDENT-R,H,0};
Point(4)={-L,H,0};
Line(1)={1,2};
Line(2)={2,3};
Line(3)={3,5};
Circle(4)={5,6,7};
Circle(5)={7,6,8};
Line(6)={8,4};
Line(7)={4,1};
Curve Loop(1)={1,2,3,4,5,6,7};
Plane Surface(1)={1};
Field[1]=MathEval;
Field[1].F="0.2*(1.0-((x-2)/(abs(x-2)+0.01)))/2.0+0.5*(1.0+((x-2.0)/(abs(x-2.0)+0.01)))/2.0";
Background Field=1;
Mesh.MeshSizeFromPoints=0;
Mesh.MeshSizeFromCurvature=0;
Mesh.MeshSizeExtendFromBoundary=0;
Physical Surface(100)={1};
Mesh 2;
Save "gmsh.m";
